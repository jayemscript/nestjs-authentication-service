# ==========================================
# NESTJS AUTHENTICATION WORKER - ENV CONFIG
# ==========================================

# ===== Application =====
PORT=4000
NODE_ENV=development

# ===== Database (PostgreSQL) =====
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=root
DB_NAME=auth_service
DB_SSL=false

# ===== Redis Cache =====
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TIMEOUT=5000
REDIS_RETRIES=3

# ===== CORS Configuration =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ===== Cookie Configuration =====
COOKIE_SECRET=your_super_secret_cookie_key_min_32_chars
COOKIE_SAMESITE=lax
COOKIE_EXPIRATION=2592000000
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true

# ===== JWT Configuration =====
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=2592000
JWT_ALGORITHM=HS256

# ===== Password Security =====
PASSWORD_MIN_LENGTH=8
PASSWORD_HASH_ROUNDS=10

# ===== Account Lockout =====
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# ===== Session Configuration =====
MAX_SESSIONS_PER_USER=5
SESSION_IDLE_TIMEOUT=60

# ===== API Key Validation =====
API_KEY_REQUIRED=false
API_KEYS=core-api:your_api_key_here,web-inventory:your_api_key_here

# ===== Feature Flags =====
FEATURE_REGISTRATION_PUBLIC=true
FEATURE_EMAIL_OTP=false
FEATURE_PASSWORD_RESET=true
FEATURE_SESSION_TRACKING=true
FEATURE_ACCOUNT_DEACTIVATION=true
FEATURE_ACCOUNT_LOCKING=false

# ===== Logging =====
LOG_LEVEL=debug
LOG_PRETTY=true

# ===== Security Headers =====
HTTPS_REDIRECT=false
CSP_ENABLED=false